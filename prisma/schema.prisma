generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Users ───────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  passwordHash   String
  role           Role      @default(loan_officer)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  groupMemberships  GroupMember[]
  sessions          Session[]
  accounts          Account[]
  loanApplications  LoanApplication[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── Roles & Permissions ────────────────────────────────────────────────────

enum Role {
  admin
  branch_manager
  loan_officer
  processor
  underwriter
}

model Permission {
  id          String  @id @default(cuid())
  action      String  // e.g. "users.create", "loans.approve"
  description String?

  rolePermissions RolePermission[]

  @@unique([action])
  @@map("permissions")
}

model RolePermission {
  id           String @id @default(cuid())
  role         Role
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@map("role_permissions")
}

// ─── Groups ─────────────────────────────────────────────────────────────────

model Group {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members GroupMember[]

  @@map("groups")
}

model GroupMember {
  id      String @id @default(cuid())
  userId  String
  groupId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@map("group_members")
}

// ─── Loan Applications ─────────────────────────────────────────────────────

enum LoanStatus {
  draft
  submitted
  in_review
  approved
  conditionally_approved
  declined
  closing
  closed
  withdrawn
}

enum LoanType {
  unsecured
  secured
}

enum LoanPurpose {
  purchase
  refinance
  home_equity
  construction
  personal
  auto
  business
  other
}

model LoanApplication {
  id              String      @id @default(cuid())
  loanNumber      String      @unique @default(cuid())
  status          LoanStatus  @default(draft)
  loanType        LoanType    @default(unsecured)
  purpose         LoanPurpose
  requestedAmount Decimal     @db.Decimal(12, 2)
  termMonths      Int
  interestRate    Decimal?    @db.Decimal(5, 4)
  notes           String?
  officerId       String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  officer           User              @relation(fields: [officerId], references: [id])
  borrowers         Borrower[]
  incomes           Income[]
  expenses          Expense[]
  collateral        CollateralAsset[]
  offers            Offer[]
  statusTransitions StatusTransition[]
  liabilities       Liability[]
  creditSummary     CreditSummary?
  closingDetail     ClosingDetail?

  @@index([officerId])
  @@index([status])
  @@index([loanType])
  @@map("loan_applications")
}

model Borrower {
  id            String   @id @default(cuid())
  applicationId String
  firstName     String
  lastName      String
  email         String?
  phone         String?
  dateOfBirth   DateTime?
  ssn           String?
  address       String?
  city          String?
  state         String?
  zipCode       String?
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("borrowers")
}

enum IncomeType {
  employment
  self_employment
  rental
  investment
  retirement
  social_security
  alimony
  child_support
  other
}

model Income {
  id            String     @id @default(cuid())
  applicationId String
  type          IncomeType
  source        String
  monthlyAmount Decimal    @db.Decimal(12, 2)
  isVerified    Boolean    @default(false)
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("incomes")
}

enum ExpenseType {
  housing
  auto_loan
  student_loan
  credit_card
  child_care
  insurance
  utilities
  other
}

model Expense {
  id            String      @id @default(cuid())
  applicationId String
  type          ExpenseType
  description   String
  monthlyAmount Decimal     @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("expenses")
}

enum AssetType {
  real_estate
  vehicle
  savings
  investment
  business
  other
}

model CollateralAsset {
  id             String    @id @default(cuid())
  applicationId  String
  type           AssetType
  description    String
  estimatedValue Decimal   @db.Decimal(12, 2)
  appraisedValue Decimal?  @db.Decimal(12, 2)
  lienPosition   Int?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("collateral_assets")
}

// ─── Offers ──────────────────────────────────────────────────────────────────

enum OfferStatus {
  draft
  pending_review
  approved
  rejected
  sent
  accepted
  expired
}

model Offer {
  id              String      @id @default(cuid())
  applicationId   String
  offeredAmount   Decimal     @db.Decimal(12, 2)
  interestRate    Decimal     @db.Decimal(5, 4)
  termMonths      Int
  monthlyPayment  Decimal     @db.Decimal(12, 2)
  conditions      String?
  status          OfferStatus @default(draft)
  isAiGenerated   Boolean     @default(false)
  createdById     String?
  reviewedById    String?
  reviewedAt      DateTime?
  reviewNotes     String?
  expiresAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([status])
  @@map("offers")
}

// ─── Status Transitions (Audit Trail) ───────────────────────────────────────

model StatusTransition {
  id            String     @id @default(cuid())
  applicationId String
  fromStatus    LoanStatus
  toStatus      LoanStatus
  reason        String?
  performedById String
  createdAt     DateTime   @default(now())

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("status_transitions")
}

// ─── Credit & Liabilities ─────────────────────────────────────────────

enum LiabilityType {
  mortgage
  auto_loan
  student_loan
  credit_card
  personal_loan
  heloc
  other
}

model Liability {
  id                 String        @id @default(cuid())
  applicationId      String
  type               LiabilityType
  creditor           String
  accountNumber      String?
  monthlyPayment     Decimal       @db.Decimal(12, 2)
  outstandingBalance Decimal       @db.Decimal(12, 2)
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("liabilities")
}

model CreditSummary {
  id               String   @id @default(cuid())
  applicationId    String   @unique
  creditScore      Int?
  creditScoreDate  DateTime?
  totalMonthlyDebt Decimal? @db.Decimal(12, 2)
  debtToIncomeRatio Decimal? @db.Decimal(5, 4)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  application LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("credit_summaries")
}

// ─── Closing ────────────────────────────────────────────────────────────

model ClosingDetail {
  id               String   @id @default(cuid())
  applicationId    String   @unique
  closingDate      DateTime?
  fundingAmount    Decimal? @db.Decimal(12, 2)
  closingAgentName String?
  closingNotes     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  application    LoanApplication      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  checklistItems ClosingChecklistItem[]

  @@map("closing_details")
}

model ClosingChecklistItem {
  id              String    @id @default(cuid())
  closingDetailId String
  name            String
  completed       Boolean   @default(false)
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  closingDetail ClosingDetail @relation(fields: [closingDetailId], references: [id], onDelete: Cascade)

  @@index([closingDetailId])
  @@map("closing_checklist_items")
}

// ─── System Config ──────────────────────────────────────────────────────────

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("system_config")
}
